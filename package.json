{
  "name": "mermaid-fixer-ts",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mermaid-fixer": "build/main.js"
  },
  "scripts": {
    "dev": "npm run build && node build/main.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node build/main.js",
    "bundle:sea": "esbuild src/sea-main.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/sea/main.cjs",
    "package:sea": "node scripts/build-sea.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "jsdom": "^26.1.0",
    "mermaid": "^11.12.3",
    "react": "^19.2.4",
    "smol-toml": "^1.4.2"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.3",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.8.2"
  }
}
