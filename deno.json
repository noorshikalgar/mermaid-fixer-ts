{
  "version": "1.0.0",
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.9",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.11",
    "@std/toml": "jsr:@std/toml@^1.0.1"
  },
  "tasks": {
    "run": "deno run --allow-read --allow-write --allow-net --allow-env src/main.ts",
    "build": "deno compile --allow-read --allow-write --allow-net --allow-env --output dist/mermaid-fixer src/main.ts",
    "build:mac-arm": "deno compile --allow-read --allow-write --allow-net --allow-env --target aarch64-apple-darwin --output dist/mermaid-fixer-mac-arm src/main.ts",
    "build:mac-x64": "deno compile --allow-read --allow-write --allow-net --allow-env --target x86_64-apple-darwin --output dist/mermaid-fixer-mac-x64 src/main.ts",
    "build:linux": "deno compile --allow-read --allow-write --allow-net --allow-env --target x86_64-unknown-linux-gnu --output dist/mermaid-fixer-linux src/main.ts",
    "build:windows": "deno compile --allow-read --allow-write --allow-net --allow-env --target x86_64-pc-windows-msvc --output dist/mermaid-fixer-windows.exe src/main.ts"
  },
  "compilerOptions": {
    "strict": true
  }
}
